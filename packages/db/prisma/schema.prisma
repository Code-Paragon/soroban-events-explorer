datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Event {
  id         String   @id
  contractId String
  topic      String
  data       String   @db.Text
  timestamp  DateTime @default(now())

  @@index([contractId])
  @@index([topic])
}

model IndexerState {
  id                String   @id @default("main_indexer")
  lastScannedLedger Int
  updatedAt         DateTime @updatedAt
}